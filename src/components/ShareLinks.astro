---
interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;
const encoded = encodeURIComponent(url);
const text = encodeURIComponent(title);
const twitterHref = `https://x.com/intent/tweet?url=${encoded}&text=${text}`;
const facebookHref = `https://www.facebook.com/sharer/sharer.php?u=${encoded}`;
---

<div class="share">
  <span class="share-label">Compartir</span>
  <a href={twitterHref} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en X">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.851L2.25 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>
  <a href={facebookHref} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Compartir en Facebook">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>
  </a>
</div>

<style>
  .share {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }

  .share-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 1px solid var(--border);
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
  }

  .share-btn:hover {
    color: var(--text);
    border-color: var(--muted2);
  }
</style>
