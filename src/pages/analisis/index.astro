---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const articulos = await getCollection('analisis');
articulos.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Análisis">
  <Nav />

  <section class="analisis-wrap">

    <div class="page-header">
      <div class="page-label">— Archivo</div>
      <h1 class="page-title">Análisis</h1>
      <p class="page-desc">Perspectiva propia sobre AI, ciberseguridad y tecnología empresarial. Sin tecnicismos innecesarios, con contexto mexicano.</p>
    </div>

    <div class="analisis-content">
      <div class="article-list">

        {articulos.map((articulo, index) => (
          <a href={`/analisis/${articulo.id}`} class="article-item">
            <div class="article-num">{String(index + 1).padStart(2, '0')}</div>
            <div class="article-body">
              <div class="article-tags">
                <span class="tag accent">{articulo.data.categoria}</span>
                {articulo.data.tags.slice(0, 1).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h3 class="article-title">{articulo.data.title}</h3>
              <p class="article-excerpt">{articulo.data.resumen}</p>
              <div class="article-meta">
                <span>{articulo.data.date}</span>
                <span>·</span>
                <span>{articulo.data.tiempo_lectura} min lectura</span>
              </div>
            </div>
          </a>
        ))}

      </div>
    </div>

  </section>

  <Footer />
</Base>

<style>
  .analisis-wrap {
    min-height: 100vh;
    padding-top: 60px;
    max-width: 1300px;
    margin: 0 auto;
    padding-left: 2.5rem;
    padding-right: 2.5rem;
  }

  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .page-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4rem;
    letter-spacing: 0.08em;
    color: var(--text);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .page-desc {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--muted2);
    font-style: italic;
    max-width: 560px;
  }

  .analisis-content {
    max-width: 860px;
  }

  .article-list { display: flex; flex-direction: column; }

  .article-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .article-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.8rem;
    color: var(--border);
    line-height: 1;
    transition: color 0.2s;
  }

  .article-item:hover .article-num { color: var(--accent); }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    background: var(--tag-bg);
    color: var(--muted2);
    border: 1px solid var(--border);
  }

  .tag.accent { color: var(--accent); border-color: var(--accent); background: rgba(0,229,255,0.05); }

  .article-title {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .article-item:hover .article-title { color: var(--accent); transition: color 0.2s; }

  .article-excerpt {
    font-size: 0.85rem;
    color: var(--muted2);
    font-weight: 300;
    line-height: 1.55;
    margin-bottom: 0.6rem;
  }

  .article-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    display: flex;
    gap: 0.5rem;
  }
</style>