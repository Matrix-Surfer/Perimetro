---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ShareLinks from '../../components/ShareLinks.astro';

export async function getStaticPaths() {
  const alertas = (await getCollection('alertas'))
    .filter(a => a.data.publicacion === 'published')
    .sort((a, b) => b.data.date.localeCompare(a.data.date));

  return alertas.map((alerta, index) => ({
    params: { slug: alerta.id },
    props: {
      alerta,
      prev: index > 0 ? alertas[index - 1] : null,
      next: index < alertas.length - 1 ? alertas[index + 1] : null,
    },
  }));
}

const { alerta, prev, next } = Astro.props;
const { Content } = await render(alerta);

const categoriaBadgeClass: Record<string, string> = {
  'Malware':      'badge-malware',
  'Phishing':     'badge-phishing',
  'Vulnerabilidad': 'badge-vulnerabilidad',
  'Fraude':       'badge-fraude',
  'Fuga de datos': 'badge-fuga',
  'Terceros':     'badge-terceros',
  'IA':           'badge-ia',
  'IoT/OT':       'badge-iot',
  'Otro':         'badge-otro',
  // legacy
  'Defacement':   'badge-vulnerabilidad',
  'Filtración':   'badge-fuga',
  'Ransomware':   'badge-malware',
  'Dark Forum':   'badge-otro',
};

const nivelBadgeClass: Record<string, string> = {
  'Bajo':    'nivel-bajo',
  'Medio':   'nivel-medio',
  'Alto':    'nivel-alto',
  'Crítico': 'nivel-critico',
};

const statusCssClass: Record<string, string> = {
  'Activa': 'status-active',
  'En monitoreo': 'status-monitoring',
  'Resuelta': 'status-resolved',
};

const categoriaLabel = alerta.data.categoria ?? alerta.data.tipo ?? 'Otro';
---

<Base title={alerta.data.title} description={alerta.data.resumen} ogType="article">
  <Nav />

  <article class="alerta-wrap">

    <header class="alerta-header">
      <a href="/alertas" class="alerta-back">← Alertas</a>
      <div class="alerta-badges">
        <span class={`alerta-badge ${categoriaBadgeClass[categoriaLabel] ?? 'badge-otro'}`}>{categoriaLabel}</span>
        {alerta.data.nivelAtencion && (
          <span class={`alerta-nivel ${nivelBadgeClass[alerta.data.nivelAtencion] ?? 'nivel-medio'}`}>{alerta.data.nivelAtencion}</span>
        )}
        <span class={`alerta-status ${statusCssClass[alerta.data.status] ?? 'status-monitoring'}`}>{alerta.data.status}</span>
      </div>
      <h1 class="alerta-title">{alerta.data.title}</h1>
      <p class="alerta-resumen">{alerta.data.resumen}</p>
      <div class="alerta-meta">
        <span>{alerta.data.date}</span>
        <span>·</span>
        <span>{alerta.data.source}</span>
      </div>
    </header>

    <div class="alerta-body">
      <Content />
      {alerta.data.link && (
        <a href={alerta.data.link} target="_blank" rel="noopener noreferrer" class="alerta-source-link">
          Leer fuente original →
        </a>
      )}
    </div>

    <ShareLinks url={`https://jsilva.io/alertas/${alerta.id}`} title={alerta.data.title} />

    <nav class="alerta-nav">
      {prev && <a href={`/alertas/${prev.id}`} class="alerta-nav-link">← Anterior</a>}
      {next && <a href={`/alertas/${next.id}`} class="alerta-nav-link alerta-nav-next">Siguiente →</a>}
    </nav>

  </article>

  <Footer />
</Base>

<style>
  .alerta-wrap {
    min-height: 100vh;
    padding-top: 60px;
    max-width: 740px;
    margin: 0 auto;
    padding-left: 2.5rem;
    padding-right: 2.5rem;
  }

  .alerta-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .alerta-back {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    display: inline-block;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .alerta-back:hover { color: var(--accent2); }

  .alerta-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .alerta-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
  }

  .badge-malware       { color: #ff6b35; border: 1px solid rgba(255,107,53,0.4); background: rgba(255,107,53,0.08); }
  .badge-phishing      { color: #a855f7; border: 1px solid rgba(168,85,247,0.4); background: rgba(168,85,247,0.08); }
  .badge-vulnerabilidad{ color: var(--accent2); border: 1px solid rgba(255,68,68,0.4); background: rgba(255,68,68,0.08); }
  .badge-fraude        { color: #ffaa00; border: 1px solid rgba(255,170,0,0.4); background: rgba(255,170,0,0.08); }
  .badge-fuga          { color: #ffaa00; border: 1px solid rgba(255,170,0,0.4); background: rgba(255,170,0,0.08); }
  .badge-terceros      { color: #14b8a6; border: 1px solid rgba(20,184,166,0.4); background: rgba(20,184,166,0.08); }
  .badge-ia            { color: #06b6d4; border: 1px solid rgba(6,182,212,0.4); background: rgba(6,182,212,0.08); }
  .badge-iot           { color: #22c55e; border: 1px solid rgba(34,197,94,0.4); background: rgba(34,197,94,0.08); }
  .badge-otro          { color: var(--muted); border: 1px solid var(--border); background: transparent; }

  .alerta-nivel {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
  }
  .nivel-bajo    { color: var(--muted); border: 1px solid var(--border); }
  .nivel-medio   { color: #ffaa00; border: 1px solid rgba(255,170,0,0.4); background: rgba(255,170,0,0.06); }
  .nivel-alto    { color: #ff6b35; border: 1px solid rgba(255,107,53,0.4); background: rgba(255,107,53,0.06); }
  .nivel-critico { color: var(--accent2); border: 1px solid rgba(255,68,68,0.5); background: rgba(255,68,68,0.1); }

  .alerta-status {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
  }

  .status-active { color: var(--accent2); border: 1px solid rgba(255,68,68,0.3); background: rgba(255,68,68,0.06); }
  .status-monitoring { color: var(--muted2); border: 1px solid var(--border); }
  .status-resolved { color: #4ade80; border: 1px solid rgba(74,222,128,0.3); background: rgba(74,222,128,0.06); }

  .alerta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    letter-spacing: 0.05em;
    color: var(--text);
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .alerta-resumen {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    color: var(--muted2);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    border-left: 2px solid var(--accent2);
    padding-left: 1rem;
  }

  .alerta-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    display: flex;
    gap: 0.5rem;
  }

  .alerta-source-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent2);
    text-decoration: none;
    border: 1px solid var(--accent2);
    padding: 0.4rem 0.9rem;
    transition: background 0.2s;
  }

  .alerta-source-link:hover {
    background: rgba(255, 68, 68, 0.08);
  }

  .alerta-body {
    padding-bottom: 6rem;
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--muted2);
  }

  .alerta-body p { margin-bottom: 1.5rem; }
  .alerta-body strong { color: var(--text); font-weight: 600; }
  .alerta-body h2 { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.08em; color: var(--text); margin: 2.5rem 0 1rem; }
  .alerta-body h3 { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 1.75rem 0 0.75rem; }
  .alerta-body ul { margin: 0 0 1.5rem 0; padding-left: 1.25rem; }
  .alerta-body ul li { margin-bottom: 0.6rem; }
  .alerta-body ol { margin: 0 0 1.5rem 0; padding-left: 1.25rem; }
  .alerta-body ol li { margin-bottom: 0.6rem; }
  .alerta-body a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }

  .alerta-nav {
    display: flex;
    padding: 2rem 0 4rem;
    border-top: 1px solid var(--border);
    margin-top: 1rem;
  }

  .alerta-nav-link {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .alerta-nav-link:hover { color: var(--accent2); }

  .alerta-nav-next { margin-left: auto; }

  @media (max-width: 768px) {
    .alerta-wrap {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .alerta-header { padding: 2.5rem 0 2rem; }
  }
</style>
